@{
    ViewData["Title"] = "Editar Producto";
    ViewData["NavActive"] = "inventario";
}

<div class="main-content">
    <h1 class="page-title">Editar producto</h1>

    <div class="card card-gold" style="max-width:780px">
        <div class="section-heading" style="margin-top:0">Datos del Producto</div>

        <form id="formProducto" novalidate>
            
            <input type="hidden" id="productoId" />

            <div class="form-group form-vertical">
                <label>Nombre del producto:</label>
                <input class="form-control" type="text" id="nombre" required maxlength="150">
                <div class="field-error" id="err-nombre">El nombre es obligatorio</div>
            </div>

            <div class="form-group form-vertical" id="grupo-sku">
                <label>Código del producto (SKU):</label>
                <input class="form-control" type="text" id="codigoSku" maxlength="20" style="text-transform:uppercase; max-width:220px;" readonly>
                <span class="text-muted" style="font-size:12px; margin-top:4px;">El código SKU no se puede modificar después de creado.</span>
            </div>

            <div class="form-row">
                <div class="form-group form-vertical">
                    <label>Marca:</label>
                    <input class="form-control" type="text" id="marca" maxlength="100">
                </div>
                <div class="form-group form-vertical">
                    <label>Modelo:</label>
                    <input class="form-control" type="text" id="modelo" maxlength="100">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group form-vertical">
                    <label>Precio de compra (RD$):</label>
                    <input class="form-control" type="number" id="precioCompra" min="0" step="0.01" required>
                    <div class="field-error" id="err-compra">Ingresa un precio válido</div>
                </div>
                <div class="form-group form-vertical">
                    <label>Precio de venta (RD$):</label>
                    <input class="form-control" type="number" id="precioVenta" min="0" step="0.01" required>
                    <div class="field-error" id="err-venta">Ingresa un precio válido</div>
                    <div class="margen-indicator" id="margenBox" style="display:none;">
                        Margen: <span class="margen-pct" id="margenPct">0%</span>
                        <span id="margenMonto">RD$ 0.00</span>
                    </div>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group form-vertical">
                    <label>Stock mínimo (alerta):</label>
                    <input class="form-control" type="number" id="stockMinimo" min="0" step="1" required>
                </div>
                <div class="form-group form-vertical">
                    <label>Unidad de medida:</label>
                    <select class="form-control" id="unidadMedida">
                        <option value="UN">Unidad (UN)</option>
                        <option value="KG">Kilogramo (KG)</option>
                        <option value="LT">Litro (LT)</option>
                        <option value="LB">Libra (LB)</option>
                        <option value="CAJA">Caja</option>
                        <option value="GAL">Galón (GAL)</option>
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group form-vertical">
                    <label>Categoría:</label>
                    <select class="form-control" id="categoria">
                        <option value="">-- Sin categoría --</option>
                    </select>
                </div>
                <div class="form-group form-vertical">
                    <label>Proveedor:</label>
                    <select class="form-control" id="proveedor">
                        <option value="">-- Sin proveedor --</option>
                    </select>
                </div>
            </div>

            <div class="form-group form-vertical">
                <label>Stock actual:</label>
                <input class="form-control" type="number" id="stockActual" readonly style="max-width:120px; background:#1a1a2e;">
                <span class="text-muted" style="font-size:12px; margin-top:4px;">El stock se modifica registrando entradas o salidas.</span>
            </div>

            <div class="btn-group-actions" style="margin-top:20px;">
                <a href="/Inventario/Productos" class="btn btn-outline">Cancelar</a>
                <button type="submit" class="btn btn-gold" id="btnConfirmar">Actualizar Producto</button>
            </div>
        </form>
    </div>
</div>

<div class="modal-overlay" id="modalActualizado">
    <div class="modal-box">
        <div class="modal-brand">
            <svg width="20" height="20" viewBox="0 0 44 44"><circle cx="22" cy="22" r="20" fill="#2c2c2c" stroke="#D4A017" stroke-width="2"/><text x="22" y="27" text-anchor="middle" font-size="14" font-weight="bold" fill="#D4A017" font-family="serif">G</text></svg>
            Gold Club
        </div>
        <div class="modal-message" id="msgExito">Producto actualizado correctamente.</div>
        <div class="modal-actions">
            <a class="btn btn-gold" href="/Inventario/Productos">✔️ Aceptar</a>
        </div>
    </div>
</div>

<div class="modal-overlay" id="modalErrorCampos">
    <div class="modal-box">
        <div class="modal-brand">
            <svg width="20" height="20" viewBox="0 0 44 44"><circle cx="22" cy="22" r="20" fill="#2c2c2c" stroke="#D4A017" stroke-width="2"/><text x="22" y="27" text-anchor="middle" font-size="14" font-weight="bold" fill="#D4A017" font-family="serif">G</text></svg>
            Gold Club
        </div>
        <div class="modal-icon-error">▲ ERROR</div>
        <div class="modal-message" id="msgError">Corrige los campos marcados en rojo.</div>
        <div class="modal-actions">
            <button class="btn btn-gold" onclick="hideModal('modalErrorCampos')">✔️ Aceptar</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', () => {
    const precioCompra = document.getElementById('precioCompra');
    const precioVenta = document.getElementById('precioVenta');
    const margenBox = document.getElementById('margenBox');
    const margenPct = document.getElementById('margenPct');
    const margenMonto = document.getElementById('margenMonto');

    const urlParams = new URLSearchParams(window.location.search);
    const id = urlParams.get('id') || window.location.pathname.split('/').pop();

    document.getElementById('productoId').value = id;

    fetch('/Inventario/EditarProducto/' + id)
        .then(res => res.json())
        .then(data => {
            document.getElementById('nombre').value = data.nombre || '';
            document.getElementById('codigoSku').value = data.codigoSku || '';
            document.getElementById('marca').value = data.marca || '';
            document.getElementById('modelo').value = data.modelo || '';
            document.getElementById('precioCompra').value = data.precioCompra || 0;
            document.getElementById('precioVenta').value = data.precioVenta || 0;
            document.getElementById('stockMinimo').value = data.stockMinimo || 0;
            document.getElementById('stockActual').value = data.stock || 0;
            document.getElementById('unidadMedida').value = data.unidadMedida || 'UN';
            calcularMargen();

            if (data.categorias) {
                const catSelect = document.getElementById('categoria');
                data.categorias.forEach(c => {
                    const opt = document.createElement('option');
                    opt.value = c.id;
                    opt.textContent = c.nombre;
                    if (c.id == data.categoriaId) opt.selected = true;
                    catSelect.appendChild(opt);
                });
            }

            if (data.proveedores) {
                const provSelect = document.getElementById('proveedor');
                data.proveedores.forEach(p => {
                    const opt = document.createElement('option');
                    opt.value = p.id;
                    opt.textContent = p.nombreEmpresa;
                    if (p.id == data.proveedorId) opt.selected = true;
                    provSelect.appendChild(opt);
                });
            }
        })
        .catch(() => {});

    function calcularMargen() {
        const compra = parseFloat(precioCompra.value);
        const venta = parseFloat(precioVenta.value);

        if (compra > 0 && venta > 0) {
            const monto = venta - compra;
            const pct = (monto / compra) * 100;

            margenBox.style.display = 'inline-flex';
            margenPct.textContent = pct.toFixed(1) + '%';
            margenMonto.textContent = 'RD$ ' + monto.toFixed(2);

            margenPct.className = 'margen-pct';
            if (venta < compra) {
                margenPct.classList.add('margen-malo');
            } else if (pct < 20) {
                margenPct.classList.add('margen-bajo');
            } else {
                margenPct.classList.add('margen-bueno');
            }
        } else {
            margenBox.style.display = 'none';
        }
    }

    precioCompra.addEventListener('input', calcularMargen);
    precioVenta.addEventListener('input', calcularMargen);

    ['nombre', 'precioCompra', 'precioVenta', 'stockMinimo'].forEach(fieldId => {
        const el = document.getElementById(fieldId);
        if (el) {
            el.addEventListener('input', () => {
                el.closest('.form-group').classList.remove('has-error');
            });
        }
    });

    document.getElementById('formProducto').addEventListener('submit', (e) => {
        e.preventDefault();
        let hayError = false;

        const nombre = document.getElementById('nombre');
        if (!nombre.value.trim()) {
            nombre.closest('.form-group').classList.add('has-error');
            hayError = true;
        }

        const compra = parseFloat(precioCompra.value);
        const venta = parseFloat(precioVenta.value);

        if (isNaN(compra) || compra < 0) {
            precioCompra.closest('.form-group').classList.add('has-error');
            hayError = true;
        }

        if (isNaN(venta) || venta < 0) {
            precioVenta.closest('.form-group').classList.add('has-error');
            document.getElementById('err-venta').textContent = 'Ingresa un precio válido';
            hayError = true;
        } else if (!isNaN(compra) && venta < compra) {
            precioVenta.closest('.form-group').classList.add('has-error');
            document.getElementById('err-venta').textContent = 'El precio de venta no puede ser menor al de compra';
            hayError = true;
        }

        if (hayError) {
            showModal('modalErrorCampos');
            return;
        }

        const btn = document.getElementById('btnConfirmar');
        btn.disabled = true;
        btn.textContent = 'Actualizando...';

        fetch('/Inventario/EditarProducto', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                id: parseInt(document.getElementById('productoId').value),
                nombre: nombre.value,
                marca: document.getElementById('marca').value,
                modelo: document.getElementById('modelo').value,
                precioCompra: compra,
                precioVenta: venta,
                stockMinimo: parseInt(document.getElementById('stockMinimo').value) || 0,
                unidadMedida: document.getElementById('unidadMedida').value,
                categoriaId: document.getElementById('categoria').value ? parseInt(document.getElementById('categoria').value) : null,
                proveedorId: document.getElementById('proveedor').value ? parseInt(document.getElementById('proveedor').value) : null
            })
        })
        .then(res => {
            if (res.ok) {
                showModal('modalActualizado');
            } else {
                showModal('modalErrorCampos');
            }
        })
        .catch(() => {
            showModal('modalErrorCampos');
        })
        .finally(() => {
            btn.disabled = false;
            btn.textContent = 'Actualizar Producto';
        });
    });
});
</script>
}