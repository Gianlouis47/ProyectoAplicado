@{
    ViewData["Title"] = "Control de Inventario";
    ViewData["NavActive"] = "inventario";
}

<div class="main-content">
    <div class="flex-between mb-2">
        <h1 class="page-title" style="margin-bottom:0">Movimientos de inventario</h1>
    </div>

    <div class="dash-stats">
        <div class="dash-stat-card success">
            <div class="dash-stat-number" id="countTotal">0</div>
            <div class="dash-stat-label">Total Productos</div>
        </div>
        <div class="dash-stat-card">
            <div class="dash-stat-number" id="countOk">0</div>
            <div class="dash-stat-label">Stock Normal</div>
        </div>
        <div class="dash-stat-card warning">
            <div class="dash-stat-number" id="countBajos">0</div>
            <div class="dash-stat-label">Stock Bajo</div>
        </div>
        <div class="dash-stat-card danger">
            <div class="dash-stat-number" id="countVacios">0</div>
            <div class="dash-stat-label">Sin Stock</div>
        </div>
    </div>

    <div class="dashboard-grid">
        <div class="card card-gold" style="grid-column: 1 / -1;">
            <div style="font-weight:600;font-size:14px;margin-bottom:12px">Productos con alertas</div>
            <div id="alertasContainer">
                <div class="text-muted">Cargando alertas...</div>
            </div>
            <div id="alertasVacias" class="empty-state" style="display:none; padding:20px;">
                <p>No hay alertas activas.</p>
            </div>
        </div>
    </div>

    <div class="section-heading mt-3">Acceso rápido</div>
    <div class="menu-grid">
        <a class="menu-card" href="/Inventario/CrearProducto">
            <svg class="menu-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 5v14"/><path d="M5 12h14"/><rect x="3" y="3" width="18" height="18" rx="2"/>
            </svg>
            <span class="menu-card-label">Crear nuevo producto</span>
        </a>
        <a class="menu-card" href="/Inventario/Productos">
            <svg class="menu-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <span class="menu-card-label">Ver productos</span>
        </a>
        <a class="menu-card" href="/Inventario/DashboardProductos">
            <svg class="menu-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 20V10M12 20V4M6 20v-6"/>
            </svg>
            <span class="menu-card-label">Dashboard de inventario</span>
        </a>
        <a class="menu-card" href="/Inventario/RegistrarEntrada">
            <svg class="menu-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
            </svg>
            <span class="menu-card-label">Registrar entrada</span>
        </a>
        <a class="menu-card" href="/Inventario/RegistrarSalida">
            <svg class="menu-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4M10 17l5-5-5-5M15 12H3"/>
            </svg>
            <span class="menu-card-label">Registrar salida</span>
        </a>
        <a class="menu-card" href="/Inventario/ConsultarMovimientos">
            <svg class="menu-card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/>
            </svg>
            <span class="menu-card-label">Consultar movimientos</span>
        </a>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', () => {
    fetch('/Inventario/DashboardProductos')
        .then(res => res.json())
        .then(data => {
            document.getElementById('countTotal').textContent = data.total || 0;
            document.getElementById('countOk').textContent = data.ok || 0;
            document.getElementById('countBajos').textContent = data.bajos || 0;
            document.getElementById('countVacios').textContent = data.vacios || 0;

            const container = document.getElementById('alertasContainer');
            const vacias = document.getElementById('alertasVacias');

            if (data.productos && data.productos.length > 0) {
                container.innerHTML = '';
                data.productos.forEach(p => {
                    let dotClass = 'dot-green';
                    let texto = '';
                    if (p.stock <= 0) {
                        dotClass = 'dot-red';
                        texto = 'Sin stock: ' + p.nombre + ' (' + p.codigoSku + ')';
                    } else if (p.stock <= p.stockMinimo) {
                        dotClass = 'dot-red';
                        texto = 'Stock bajo: ' + p.nombre + ' (' + p.stock + '/' + p.stockMinimo + ')';
                    } else {
                        texto = p.nombre + ' (' + p.codigoSku + ')';
                    }

                    const div = document.createElement('div');
                    div.className = 'alert-item';
                    div.innerHTML = '<div class="alert-dot ' + dotClass + '"></div><span>' + texto + '</span>';
                    container.appendChild(div);
                });
                vacias.style.display = 'none';
            } else {
                container.innerHTML = '';
                vacias.style.display = 'block';
            }
        })
        .catch(() => {
            document.getElementById('alertasContainer').innerHTML = '<div class="text-muted">No se pudo conectar a la base de datos.</div>';
        });
});
</script>
}